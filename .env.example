# ================================================================
# SCALPER BOT — Configuration
# ================================================================

# --- BINANCE FUTURES API ---
# Testnet Futures: https://testnet.binancefuture.com
# Live Futures: https://www.binance.com/fr/my/settings/api-management
BINANCE_API_KEY=iAUGdqIcRH1j1T7P6vIAqKLTAVCxWT36M6rO1v8fDjD3oBJBl3eG6YHBLne3wrD8
BINANCE_SECRET_KEY=qb0GwRuUoJOkBOqsMDP7zFCk8bxUpVQHym8vSbBmRWM9FAPjgKiOhHdz1BdvUXDw


# --- MODE ---
# "testnet" = Binance Futures Testnet (https://testnet.binancefuture.com)
# "live"    = Binance Futures réel
TRADE_MODE=testnet

# --- PARAMÈTRES SCALPING ---
# Paires à surveiller (séparées par virgule)
TRADE_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT

# Capital par trade (en USDT)
TRADE_AMOUNT_USDT=20

# Levier (1 = pas de levier, 3 = x3, 5 = x5)
# ATTENTION: Plus le levier est élevé, plus le risque est grand
LEVERAGE=3

# Nombre maximum de positions ouvertes simultanément
MAX_POSITIONS=3

# Take Profit en % (ferme le trade dès ce gain)
TAKE_PROFIT_PCT=0.4

# Stop Loss en % (coupe la perte immédiatement)
STOP_LOSS_PCT=0.25

# Trailing Stop (si true, le SL monte avec le prix pour sécuriser les gains)
TRAILING_STOP=true
TRAILING_ACTIVATION_PCT=0.2
TRAILING_DISTANCE_PCT=0.15

# Intervalle de scan du marché en ms (3000 = 3 secondes)
SCAN_INTERVAL_MS=3000

# --- FILTRES DE QUALITÉ ---
# RSI min/max pour entrer en position
RSI_OVERSOLD=38
RSI_OVERBOUGHT=62

# Volatilité minimum (ATR/prix en %) pour trader
MIN_VOLATILITY_PCT=0.05

# Volume minimum vs moyenne (0.8 = au moins 80% du volume moyen)
MIN_VOLUME_RATIO=0.6

# --- GESTION DU RISQUE ---
# Perte maximale quotidienne avant arrêt automatique du bot (en USDT)
MAX_DAILY_LOSS=50

# Nombre max de trades par heure par paire
MAX_TRADES_PER_HOUR=12

# Cooldown entre 2 trades sur la même paire (ms)
TRADE_COOLDOWN_MS=15000

# --- SERVEUR ---
PORT=3000
